	<!-- Canopy position switch -->
	<animation>
		<type>knob</type>
		<object-name>canopy-pos-switch</object-name>
		<property>sim/model/A-10/controls/canopy/canopy-switch</property>
		<factor>30</factor>
		<offset-deg>-60</offset-deg>
		<axis>
			<object-name>canopy-pos-switch-axis</object-name>
		</axis>
		<action>
			<binding>
				<command>nasal</command>
				<script>canopy.canopy_switch(cmdarg().getNode("offset").getValue())</script>
			</binding>
		</action>
		<release>
			<binding>
				<command>nasal</command>
				<script>canopy.canopy_hold()</script>
			</binding>
		</release>
	</animation>

		<!-- VHF1 (AN/ARC-186 replacement) interactions -->
	<animation>
		<type>knob</type>
		<visible>true</visible>
		<object-name>VHF1_10s</object-name>
		<increase>
			<binding>
				<command>property-adjust</command>
				<property>sim/model/A-10/instrumentation/vhf/frequencies/alt-selected-mhz-x10</property>
				<step>1</step>
				<min>1</min>
				<max>16</max>
				<resolution>1</resolution>
				<wrap>true</wrap>
			</binding>
			<binding>
				<command>nasal</command>
				<script>nav_scripts.alt_freq_to_freq();</script>
			</binding>
		</increase>
		<decrease>
			<binding>
				<command>property-adjust</command>
				<property>sim/model/A-10/instrumentation/vhf/frequencies/alt-selected-mhz-x10</property>
